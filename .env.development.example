# 개발 환경 설정 — 실제 API 키 없이 로컬 실행
# 복사 후 .env로 사용: cp .env.development .env

# ─── 텔레그램 봇 (개발 시 빈 값으로 알림 비활성화)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── 외부 API 키 (빈 값 → 폴백 또는 mock 사용)
COINGECKO_API_KEY=
FRED_API_KEY=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ─── 데이터베이스 (로컬 파일)
DATABASE_PATH=./crypto.db

# ─── 대시보드 보안 (개발용 기본값)
PIN_CODE=1234
ADMIN_KEY=dev-admin-key
APP_SECRET=dev-secret-change-in-prod

# ─── 봇 설정
LOG_LEVEL=DEBUG
EMERGENCY_THRESHOLD=80

# ─── CORS (로컬 Vite 개발 서버)
CORS_ORIGINS=http://localhost:5173

# ─── Webhook (개발 시 비활성화)
TELEGRAM_WEBHOOK_SECRET=
