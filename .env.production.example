# 프로덕션 환경 설정 — Railway 배포 시 환경변수로 주입
# 이 파일을 직접 사용하지 말고 Railway Dashboard에서 설정할 것

# ─── 텔레그램 봇 (필수)
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_CHAT_ID=REPLACE_ME

# ─── 외부 API 키 (필수)
COINGECKO_API_KEY=REPLACE_ME
FRED_API_KEY=REPLACE_ME
BYBIT_API_KEY=REPLACE_ME
BYBIT_API_SECRET=REPLACE_ME

# ─── 데이터베이스 (Railway Volume 마운트 경로)
DATABASE_PATH=/data/crypto.db

# ─── 대시보드 보안 (강력한 값으로 교체 필수)
PIN_CODE=REPLACE_WITH_STRONG_PIN
ADMIN_KEY=REPLACE_WITH_STRONG_KEY
APP_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING

# ─── 봇 설정
LOG_LEVEL=INFO
EMERGENCY_THRESHOLD=80

# ─── CORS (배포 도메인으로 교체)
CORS_ORIGINS=https://your-app.railway.app

# ─── Webhook 보안 (권장)
TELEGRAM_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET
