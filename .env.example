# ─── 텔레그램 봇 ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─── 외부 API 키 ───────────────────────────────────────────────
# CoinGecko Demo API (https://www.coingecko.com/en/api)
COINGECKO_API_KEY=CG-xxxxxxxxxxxxxxxxxxxx

# FRED API (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key

# Bybit API (없어도 공개 데이터 접근 가능 — ccxt.bybit 사용)
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# ─── 데이터베이스 ─────────────────────────────────────────────
# 로컬: ./crypto.db  /  Railway Volume: /data/crypto.db
DATABASE_PATH=/data/crypto.db

# ─── 대시보드 보안 ────────────────────────────────────────────
# PIN 인증 (4자리 숫자)
PIN_CODE=1234
# 리서치 글 관리자 키
ADMIN_KEY=your_admin_key_here

# ─── 봇 설정 ──────────────────────────────────────────────────
LOG_LEVEL=INFO
# SYMBOLS=BTC/USDT,ETH/USDT
EMERGENCY_THRESHOLD=80
